<?xml version="1.0" encoding="UTF-8"?>

<OpDefCollection
        PackageName="MatMulCustomOpPackage"
        Domain="aisw"
        Version="1.0">

    <OpDefList>
        <OpDef>
            <Name>MatMulCustom</Name>
            
            <Description>
                <Content>
                    FLOAT32 batched matrix multiplication:
                    output[B,H,M,N] =
                    lhs[B,H,M,N] * rhs[B,H,K,N].
                    Batch broadcasting and transpose are not supported.
                </Content>
            </Description>

            <Input>
                <Name>lhs</Name>
                <Description>
                    <Content>Left Matrix with shape [B,H,M,K].</Content>
                </Description>
                <Mandatory>true</Mandatory>
                <Datatype>BACKEND_SPECIFIC</Datatype>
                <Shape>
                    <Rank>4D</Rank>
                    <Text>[batch, head, rows, reduction]</Text>
                </Shape>
            </Input>

            <Input>
                <Name>rhs</Name>
                <Description>
                    <Content>Right matrix with shape [B,H,K,N]</Content>
                </Description>
                <Mandatory>true</Mandatory>
                <Datatype>BACKEND_SPECIFIC</Datatype>
                <Shape>
                    <Rank>4D</Rank>
                    <Text>[batch, head, reduction, columns]</Text>
                </Shape>
            </Input>

            <Output>
                <Name>output</Name>
                <Description>
                    <Content>Matrix product with shape [B,H,M,N]</Content>
                </Description>
                <Mandatory>true</Mandatory>
                <Datatype>BACKEND_SPECIFIC</Datatype>
                <Shape>
                    <Rank>4D</Rank>
                    <Text>[batch, head, row, columns]</Text>
                </Shape>
            </Output>
            
            <SupportedBackend>HTP</SupportedBackend>
        </OpDef>
    </OpDefList>

    <SupplementalOpDefList Backend="HTP">
        <SupportedOps>
            <OpName>MatMulCustom</OpName>
        </SupportedOps>

        <SupplementalOpDef>
            <Name>MatMulCustom</Name>
            
            <Input>
                <Name>lhs</Name>
                <Datatype>QNN_DATATYPE_FLOAT_32</Datatype>
            </Input>

            <Input>
                <Name>rhs</Name>
                <Datatype>QNN_DATATYPE_FLOAT_32</Datatype>
            </Input>

            <Output>
                <Name>output</Name>
                <Datatype>QNN_DATATYPE_FLOAT_32</Datatype>
            </Output>
        </SupplementalOpDef>
    </SupplementalOpDefList>
</OpDefCollection>